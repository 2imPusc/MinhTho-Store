MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/minhtho-store?retryWrites=true&w=majority
JWT_ACCESS_KEY=your_access_secret_key_here
JWT_REFRESH_KEY=your_refresh_secret_key_here
PORT=5000
# Danh sách origin được phép (phân tách bởi dấu phẩy). Để trống = cho phép tất cả (chỉ dùng dev).
# Ví dụ: ALLOWED_ORIGINS=http://localhost:5173,http://192.168.1.100:5173
ALLOWED_ORIGINS=
NODE_ENV=development
# Khi = "true", BE serve luôn client/dist (production 1-origin, dùng với Cloudflare Tunnel)
SERVE_CLIENT=false
